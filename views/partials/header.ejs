      <a class="font-label-md text-label-md transition-colors duration-200 <%= activePage === 'partners' ? 'text-primary border-b-2 border-primary font-bold pb-1' : 'text-on-surface-variant font-medium hover:text-primary' %>" href="/cozum-ortaklarimiz">Çözüm Ortaklarımız</a>
