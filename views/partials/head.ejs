<!DOCTYPE html>
<html class="scroll-smooth" lang="tr">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&family=Hanken+Grotesk:wght@400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "primary": "#002a73",
            "on-primary": "#ffffff",
            "on-surface": "#1a1b20",
            "on-surface-variant": "#444651",
            "surface": "#faf8ff",
            "surface-industrial": "#F2F2F2",
            "surface-bright": "#faf8ff",
            "surface-variant": "#e3e2e9",
            "surface-container": "#eeedf4",
            "surface-container-low": "#f4f3fa",
            "surface-container-lowest": "#ffffff",
            "outline": "#747682",
            "outline-variant": "#c4c6d3",
            "primary-container": "#22428c",
            "primary-fixed": "#dae1ff",
            "primary-fixed-dim": "#b3c5ff",
            "on-primary-container": "#98b2ff",
            "on-primary-fixed": "#001849",
            "on-primary-fixed-variant": "#23438d",
            "secondary": "#5f5e5e",
            "tertiary-fixed-dim": "#b6c4ff",
            "status-success": "#1B5E20",
            "background": "#faf8ff"
          },
          borderRadius: { DEFAULT: "0.125rem", lg: "0.25rem", xl: "0.5rem", full: "0.75rem" },
          spacing: {
            "margin-desktop": "80px", "gutter-desktop": "32px",
            "gutter-mobile": "16px", "margin-mobile": "20px", "container-max": "1280px"
          },
          fontFamily: {
            "headline-lg": ["Montserrat"], "headline-md": ["Montserrat"],
            "headline-xl": ["Montserrat"], "body-lg": ["Hanken Grotesk"],
            "body-md": ["Hanken Grotesk"], "label-md": ["Hanken Grotesk"], "label-sm": ["Hanken Grotesk"]
          },
          fontSize: {
            "headline-xl": ["48px", { lineHeight: "56px", letterSpacing: "-0.02em", fontWeight: "700" }],
            "headline-lg": ["32px", { lineHeight: "40px", letterSpacing: "-0.01em", fontWeight: "700" }],
            "headline-md": ["24px", { lineHeight: "32px", fontWeight: "600" }],
            "body-lg": ["18px", { lineHeight: "28px", fontWeight: "400" }],
            "body-md": ["16px", { lineHeight: "24px", fontWeight: "400" }],
            "label-md": ["14px", { lineHeight: "20px", letterSpacing: "0.05em", fontWeight: "600" }],
            "label-sm": ["12px", { lineHeight: "16px", fontWeight: "500" }]
          }
        }
      }
    };
  </script>
  <style>
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; vertical-align: middle; }
    .industrial-shadow { box-shadow: 0 4px 12px -2px rgba(0, 42, 115, 0.08); }
    .hero-clip { clip-path: polygon(0 0, 100% 0, 100% 90%, 0% 100%); }
    .product-card-hover:hover { border-color: #002a73; box-shadow: 0 8px 24px rgba(0, 42, 115, 0.08); transform: translateY(-2px); }
    .sidebar-sticky { position: sticky; top: 100px; max-height: calc(100vh - 120px); overflow-y: auto; }
    @media (max-width: 1023px) {
      .px-margin-desktop { padding-left: 20px; padding-right: 20px; }
    }
  </style>
</head>
<body class="bg-surface-industrial text-on-surface font-body-md">
