<%- include('layout-head') %>
<%- include('layout-sidebar') %>

<h2 class="text-2xl font-bold text-gray-900 mb-6">Duyuru Yönetimi</h2>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
    <h3 class="font-semibold text-gray-900 mb-4">Yeni Duyuru Ekle</h3>
    <form method="POST" action="/admin/duyurular" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Başlık *</label>
        <input name="title" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm"/>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">İçerik</label>
        <textarea name="content" rows="3" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm"></textarea>
      </div>
      <label class="flex items-center gap-2 text-sm">
        <input type="checkbox" name="is_active" value="1" checked class="rounded text-primary"/> Aktif
      </label>
      <button type="submit" class="w-full bg-primary text-white py-2.5 rounded-lg font-medium text-sm">Duyuru Ekle</button>
    </form>
  </div>

  <div class="lg:col-span-2 space-y-3">
    <% announcements.forEach(a => { %>
    <div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm flex items-start justify-between gap-4">
      <div>
        <div class="flex items-center gap-2">
          <h4 class="font-semibold text-gray-900"><%= a.title %></h4>
          <span class="text-xs px-2 py-0.5 rounded <%= a.is_active ? 'bg-green-100 text-green-700' : 'bg-gray-100' %>"><%= a.is_active ? 'Aktif' : 'Pasif' %></span>
        </div>
        <p class="text-gray-500 text-sm mt-1"><%= a.content %></p>
        <p class="text-gray-300 text-xs mt-2"><%= a.created_at %></p>
      </div>
      <form method="POST" action="/admin/duyurular/<%= a.id %>/sil" onsubmit="return confirm('Silmek istediğinize emin misiniz?')">
        <button type="submit" class="text-red-500 hover:text-red-700 p-1">
          <span class="material-symbols-outlined">delete</span>
        </button>
      </form>
    </div>
    <% }) %>
    <% if (announcements.length === 0) { %>
    <p class="text-gray-400 text-center py-8">Henüz duyuru yok.</p>
    <% } %>
  </div>
</div>

<%- include('layout-foot') %>
