<%- include('layout-head') %>
<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-primary to-primary-light p-4">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-8">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-primary">OZONER</h1>
      <p class="text-gray-500 mt-2">Yönetim Paneli Girişi</p>
    </div>
    <% if (error) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm flex items-center gap-2">
      <span class="material-symbols-outlined text-sm">error</span> <%= error %>
    </div>
    <% } %>
    <form method="POST" action="/admin/login" class="space-y-5">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="username">Kullanıcı Adı</label>
        <input class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-primary focus:border-primary" id="username" name="username" type="text" required autocomplete="username"/>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="password">Şifre</label>
        <input class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-primary focus:border-primary" id="password" name="password" type="password" required autocomplete="current-password"/>
      </div>
      <button type="submit" class="w-full bg-primary text-white py-3 rounded-lg font-semibold hover:opacity-90 transition-all">Giriş Yap</button>
    </form>
    <p class="text-center text-gray-400 text-xs mt-6">
      <a href="/" class="hover:text-primary">← Siteye dön</a>
    </p>
  </div>
</div>
</body>
</html>
