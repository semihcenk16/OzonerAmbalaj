<div class="flex min-h-screen">
  <aside class="w-64 bg-primary text-white flex-shrink-0 hidden md:flex flex-col">
    <div class="p-6 border-b border-white/10">
      <h1 class="text-xl font-bold">OZONER</h1>
      <p class="text-white/60 text-sm mt-1">Yönetim Paneli</p>
    </div>
    <nav class="flex-1 p-4 space-y-1">
      <a href="/admin" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 transition-colors <%= title === 'Yönetim Paneli' ? 'bg-white/15' : '' %>">
        <span class="material-symbols-outlined text-sm">dashboard</span> Dashboard
      </a>
      <a href="/admin/urunler" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 transition-colors <%= title === 'Ürün Yönetimi' ? 'bg-white/15' : '' %>">
        <span class="material-symbols-outlined text-sm">inventory_2</span> Ürünler
      </a>
      <a href="/admin/slider" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 transition-colors <%= title === 'Slider Yönetimi' ? 'bg-white/15' : '' %>">
        <span class="material-symbols-outlined text-sm">view_carousel</span> Slider
      </a>
      <a href="/admin/duyurular" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 transition-colors <%= title === 'Duyuru Yönetimi' ? 'bg-white/15' : '' %>">
        <span class="material-symbols-outlined text-sm">campaign</span> Duyurular
      </a>
      <a href="/admin/cozum-ortaklari" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 transition-colors <%= title === 'Çözüm Ortakları Yönetimi' ? 'bg-white/15' : '' %>">
        <span class="material-symbols-outlined text-sm">handshake</span> Çözüm Ortakları
      </a>
      <a href="/admin/mesajlar" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 transition-colors <%= title === 'İletişim Mesajları' ? 'bg-white/15' : '' %>">
        <span class="material-symbols-outlined text-sm">mail</span> Mesajlar
      </a>
      <a href="/" target="_blank" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 transition-colors">
        <span class="material-symbols-outlined text-sm">open_in_new</span> Siteyi Görüntüle
      </a>
    </nav>
    <div class="p-4 border-t border-white/10">
      <p class="text-white/60 text-sm mb-2">Hoş geldin, <%= username %></p>
      <form method="POST" action="/admin/logout">
        <button type="submit" class="w-full flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 px-4 py-2 rounded-lg text-sm transition-colors">
          <span class="material-symbols-outlined text-sm">logout</span> Çıkış Yap
        </button>
      </form>
    </div>
  </aside>

  <div class="flex-1 flex flex-col min-w-0">
    <header class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between md:hidden">
      <h1 class="font-bold text-primary">OZONER Admin</h1>
      <a href="/admin/logout" class="text-sm text-gray-500">Çıkış</a>
    </header>
    <main class="flex-1 p-6 md:p-8 overflow-auto">
