<%- include('layout-head') %>
<%- include('layout-sidebar') %>

<h2 class="text-2xl font-bold text-gray-900 mb-6">İletişim Mesajları</h2>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
  <% if (messages.length === 0) { %>
  <p class="text-gray-400 text-center py-12">Henüz mesaj yok.</p>
  <% } else { %>
  <div class="divide-y divide-gray-100">
    <% messages.forEach(msg => { %>
    <div class="p-6 hover:bg-gray-50">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="font-semibold text-gray-900"><%= msg.name %></p>
          <a href="mailto:<%= msg.email %>" class="text-primary text-sm hover:underline"><%= msg.email %></a>
          <% if (msg.subject) { %><p class="text-gray-600 text-sm mt-1">Konu: <%= msg.subject %></p><% } %>
        </div>
        <span class="text-gray-400 text-xs whitespace-nowrap"><%= msg.created_at %></span>
      </div>
      <p class="text-gray-600 mt-3 leading-relaxed"><%= msg.message %></p>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>

<%- include('layout-foot') %>
