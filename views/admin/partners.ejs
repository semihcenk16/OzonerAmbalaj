<%- include('layout-head') %>
<%- include('layout-sidebar') %>

<div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 mb-6">
  <h2 class="text-2xl font-bold text-gray-900">Çözüm Ortaklarımız Yönetimi</h2>
  <p class="text-gray-500 text-sm"><%= partners.length %> ortak listeleniyor</p>
</div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
  <div class="xl:col-span-1">
    <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm sticky top-6">
      <h3 class="font-semibold text-gray-900 mb-4">
        <%= editPartner ? 'Ortak Düzenle' : 'Yeni Ortak Ekle' %>
      </h3>
      <form method="POST" action="<%= editPartner ? '/admin/cozum-ortaklari/' + editPartner.id : '/admin/cozum-ortaklari' %>" enctype="multipart/form-data" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Marka Adı *</label>
          <input name="name" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-primary" value="<%= editPartner ? editPartner.name : '' %>" placeholder="Örn: Unilever"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Logo URL</label>
          <input name="logo_url" type="url" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-primary" placeholder="https://..." value="<%= editPartner && editPartner.logo_url && !editPartner.logo_url.startsWith('/uploads') ? editPartner.logo_url : '' %>"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">veya Logo Yükle</label>
          <input name="logo" type="file" accept="image/*" class="w-full text-sm"/>
        </div>
        <% if (editPartner && editPartner.logo_url) { %>
        <img src="<%= editPartner.logo_url %>" alt="" class="w-full h-20 object-contain bg-gray-50 rounded-lg border p-2"/>
        <% } %>
        <label class="flex items-center gap-2 text-sm">
          <input type="checkbox" name="is_active" value="1" <%= !editPartner || editPartner.is_active ? 'checked' : '' %> class="rounded text-primary"/>
          Sitede göster
        </label>
        <div class="flex gap-2">
          <button type="submit" class="flex-1 bg-primary text-white py-2.5 rounded-lg font-medium text-sm hover:opacity-90">
            <%= editPartner ? 'Güncelle' : 'Ortak Ekle' %>
          </button>
          <% if (editPartner) { %>
          <a href="/admin/cozum-ortaklari" class="px-4 py-2.5 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">İptal</a>
          <% } %>
        </div>
      </form>
    </div>
  </div>

  <div class="xl:col-span-2">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <% if (partners.length === 0) { %>
      <p class="text-gray-400 text-center py-12">Henüz çözüm ortağı eklenmemiş.</p>
      <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Logo</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Marka</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Durum</th>
              <th class="text-right px-4 py-3 font-medium text-gray-600">İşlemler</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% partners.forEach(p => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3">
                <% if (p.logo_url) { %>
                <img src="<%= p.logo_url %>" alt="" class="w-14 h-10 object-contain bg-gray-50 rounded border p-1"/>
                <% } else { %>
                <span class="w-14 h-10 flex items-center justify-center bg-primary/10 text-primary font-bold rounded"><%= p.name.charAt(0) %></span>
                <% } %>
              </td>
              <td class="px-4 py-3 font-medium text-gray-900"><%= p.name %></td>
              <td class="px-4 py-3">
                <span class="text-xs px-2 py-1 rounded <%= p.is_active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">
                  <%= p.is_active ? 'Aktif' : 'Pasif' %>
                </span>
              </td>
              <td class="px-4 py-3 text-right">
                <div class="flex items-center justify-end gap-2">
                  <a href="/admin/cozum-ortaklari/duzenle/<%= p.id %>" class="p-1.5 text-gray-400 hover:text-blue-600" title="Düzenle">
                    <span class="material-symbols-outlined text-lg">edit</span>
                  </a>
                  <form method="POST" action="/admin/cozum-ortaklari/<%= p.id %>/sil" class="inline" onsubmit="return confirm('Bu ortağı silmek istediğinize emin misiniz?')">
                    <button type="submit" class="p-1.5 text-gray-400 hover:text-red-600" title="Sil">
                      <span class="material-symbols-outlined text-lg">delete</span>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('layout-foot') %>
